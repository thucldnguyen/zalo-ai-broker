# Zalo API Configuration
# Get these from https://developers.zalo.me/
ZALO_APP_ID=your_app_id_here
ZALO_APP_SECRET=your_app_secret_here
ZALO_ACCESS_TOKEN=your_access_token_here
ZALO_VERIFY_TOKEN=zalo_broker_assistant_2026

# Default broker ID for single-user testing
DEFAULT_BROKER_ID=your_name

# Optional: Server configuration
HOST=0.0.0.0
PORT=8000

# Anthropic LLM (optional – heuristic fallback used when not set)
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model overrides (defaults to claude-haiku-4-5-20251001 for both)
# ANTHROPIC_MODEL_EXTRACTION=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL_REPLY=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # single override for both
